<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.b5ane.quantum.mesh</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/var/root/scheduler.py</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/var/log/quantum_mesh.log</string>
    
    <key>StandardErrorPath</key>
    <string>/var/log/quantum_mesh.error.log</string>
    
    <key>UserName</key>
    <string>root</string>
    
    <key>GroupName</key>
    <string>wheel</string>
    
    <key>WorkingDirectory</key>
    <string>/var/root</string>
</dict>
</plist>
